# ===== Ports =====
API_PORT=8081
NGINX_PORT=8443
DB_PORT=5432
KEYCLOAK_PORT=18080

# ===== API =====
API_ADDR=:8080
UPLOAD_DIR=/uploads

# ===== PostgreSQL =====
POSTGRES_USER=forest
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=forestmap
POSTGRES_SSLMODE=disable

# ===== Keycloak (admin) =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# ===== OIDC for backend JWT validation =====
OIDC_ISSUER=http://localhost:8443/auth/realms/forestmap
OIDC_JWKS_URL=http://keycloak:8080/auth/realms/forestmap/protocol/openid-connect/certs

# ===== Optional: test clients =====
DRONE_CLIENT_ID=forestmap-drone
DRONE_CLIENT_SECRET=CHANGE_ME

VIEWER_CLIENT_ID=forestmap-viewer-bot

VIEWER_CLIENT_SECRET=CHANGE_ME
